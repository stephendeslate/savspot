# =============================================================================
# SavSpot — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.production.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables gracefully degrade when unset.
# =============================================================================

# ── Domain ──────────────────────────────────────────────────────────────────
# [REQUIRED] Your domain (Caddy auto-provisions HTTPS via Let's Encrypt)
# Use "localhost" for local testing (serves HTTP only)
DOMAIN=localhost

# Public URL of your SavSpot instance (include https:// for production)
WEB_URL=http://localhost

# ── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL credentials (used by docker-compose for self-host).
# For hosted Supabase deployments these are unused — DATABASE_URL/DIRECT_URL
# below take precedence and point at Supabase's Supavisor pooler / direct host.
POSTGRES_USER=savspot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=savspot

# Hosted-Supabase deployment: set both URLs explicitly. DATABASE_URL goes
# through the Supavisor txn pooler (port 6543); DIRECT_URL is the direct
# session-mode connection used by Prisma Migrate.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require

# ── Redis ───────────────────────────────────────────────────────────────────
# Redis password (leave empty for no auth in isolated Docker network)
REDIS_PASSWORD=

# ── JWT Authentication ──────────────────────────────────────────────────────
# [REQUIRED] RS256 key pair, base64-encoded
# Generate with: ./scripts/generate-keys.sh
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption ──────────────────────────────────────────────────────────────
# [REQUIRED] 32-byte hex key for encrypting sensitive data at rest
# Generated automatically by ./scripts/generate-keys.sh
ENCRYPTION_KEY=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Optional — emails are logged to console when unset
# Get your API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=

# ── File Uploads (Cloudflare R2) ────────────────────────────────────────────
# Optional — upload endpoints return errors when unset
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=savspot-uploads
R2_PUBLIC_URL=

# ── Payments (Stripe) ──────────────────────────────────────────────────────
# Optional — payment features disabled when unset
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=1

# ── Google OAuth ────────────────────────────────────────────────────────────
# Optional — Google login disabled when unset
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ── Internal API URL ────────────────────────────────────────────────────────
# Used by the web container to reach the API container
# Do not change unless you modify the Docker network
NEXT_PUBLIC_API_URL=http://api:3001
