# =============================================================================
# SavSpot API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# Do NOT commit .env to version control.
# =============================================================================

# ---------- Core ----------
NODE_ENV=development
PORT=3001

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/savspot_dev

# ---------- Redis (Upstash / local) ----------
REDIS_URL=redis://localhost:6379

# ---------- Frontend URL (CORS origin) ----------
WEB_URL=http://localhost:3000

# ---------- Sprint 2+ (uncomment when needed) ----------
# JWT_SECRET=
# JWT_EXPIRATION=15m
# JWT_REFRESH_EXPIRATION=7d
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
