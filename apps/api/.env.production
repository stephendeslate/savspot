VAPID_PUBLIC_KEY=BGNpW_6loG2ZngzVAXtYRu8jFYLa7SC17VNXzgP1TAHfjdKpJ-otWLQuSFmIpD9Fs0rXluiT-TsRZIpg9hIlE9E
VAPID_PRIVATE_KEY=vk7-LL562AgP-tg7AY90yFpyaTxUdcWQAaq-S5yyAJY
VAPID_SUBJECT=mailto:support@savspot.co

