# =============================================================================
# SavSpot API — Production Environment Variables
# Generated: 2026-03-04
# =============================================================================
# IMPORTANT: Review and update all values marked with TODO before deploying.
# Set these as Fly.io secrets: fly secrets set KEY=value --app savspot-api
# =============================================================================

# ---------- Core ----------
NODE_ENV=production
PORT=3001

# ---------- Database (PostgreSQL) ----------
# TODO: Replace with your Fly.io PostgreSQL connection string
DATABASE_URL=postgresql://savspot:CHANGE_ME@savspot-db.flycast:5432/savspot?schema=public

# ---------- Redis ----------
# TODO: Replace with your Upstash Redis URL
REDIS_URL=redis://default:CHANGE_ME@your-redis.upstash.io:6379

# ---------- Frontend URL (CORS origin) ----------
# TODO: Replace with your Vercel production URL
WEB_URL=https://app.savspot.co

# ---------- JWT (RS256 key pair, base64-encoded) ----------
# Generated fresh — ready to use
JWT_PRIVATE_KEY_
JWT_PUBLIC_KEY_
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Google OAuth (user login) ----------
# TODO: Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.savspot.co/api/auth/google/callback

# ---------- Resend (transactional email) ----------
# TODO: Get API key at https://resend.com, verify domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mail.savspot.co

# ---------- Cloudflare R2 (file uploads) ----------
# TODO: Configure at https://dash.cloudflare.com > R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=savspot-uploads
R2_PUBLIC_URL=

# ---------- Stripe (payments) ----------
# TODO: Get live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=1

# ---------- Twilio (SMS) ----------
# TODO: Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------- Google Calendar OAuth ----------
# TODO: Enable Calendar API, create separate OAuth client
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api.savspot.co/api/auth/google-calendar/callback
GOOGLE_CALENDAR_WEBHOOK_URL=https://api.savspot.co/api/webhooks/google-calendar

# ---------- VAPID (Browser Push Notifications) ----------
