# =============================================================================
# SavSpot — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# ---- Database ----
# PostgreSQL connection string. In hosted Supabase deployments this should be
# the Supavisor pooler URL (txn mode, port 6543) — the runtime path uses
# transaction-scoped `set_config('app.current_tenant', $1, TRUE)` for RLS,
# which is compatible with txn-mode pooling.
DATABASE_URL="postgresql://savspot:savspot_dev@localhost:5432/savspot_dev?schema=public"

# Direct (session-mode) database connection. Used by Prisma Migrate CLI
# (`pnpm db:migrate:deploy`, `pnpm db:migrate:dev`) and any code path that
# requires session-level features the txn pooler doesn't support.
# Locally, the Prisma scripts default DIRECT_URL to DATABASE_URL when unset,
# so leaving this commented is fine for single-DB local dev.
# In Supabase production, set this to the direct DB URL on port 5432:
# DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"

# ---- Redis ----
# Redis connection URL (used for caching + BullMQ)
REDIS_URL="redis://localhost:6379"

# ---- App ----
NODE_ENV=development
PORT=3001

# ---- Frontend URL ----
# Used for CORS and email links
WEB_URL="http://localhost:3000"

# ---- JWT (RS256 key pair, base64-encoded) ----
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'
#   cat public.pem | base64 | tr -d '\n'
# Optional in development — a dev key pair will be generated if missing
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ---- Google OAuth ----
# Optional — Google login will be disabled if not set
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# ---- Apple Sign-In ----
# Optional — Apple login will be disabled if not set
# Requires Apple Developer account: https://developer.apple.com
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_CALLBACK_URL="http://localhost:3001/api/auth/apple/callback"

# ---- Resend (transactional email) ----
# Optional — emails will be logged to console if not set
# Get your API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="onboarding@savspot.co"
# Webhook signing secret from Resend dashboard (for Svix signature verification)
RESEND_WEBHOOK_SECRET=

# ---- Storage provider (file uploads) ----
# Selects which backend serves the upload presigned-URL endpoint.
# `r2` (default) uses Cloudflare R2 via the S3-compatible API.
# `supabase` uses Supabase Storage (post-Phase-3 cutover).
STORAGE_PROVIDER=r2

# ---- Cloudflare R2 (used when STORAGE_PROVIDER=r2) ----
# Optional — upload endpoints will return an error if not set
# Configure in Cloudflare dashboard > R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME="savspot-uploads"
# Public URL for serving uploaded files (e.g. custom domain or r2.dev URL)
R2_PUBLIC_URL=

# ---- Supabase Storage (used when STORAGE_PROVIDER=supabase) ----
# SUPABASE_URL is the project endpoint, e.g. https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the service-role JWT (NOT the anon key); needed
# for server-side createSignedUploadUrl calls. Treat as a secret.
# SUPABASE_STORAGE_BUCKET defaults to "savspot-uploads" — keep symmetric with R2.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET="savspot-uploads"

# ---- Stripe (payments) ----
# Required for payment processing — get keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secrets — configure at https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
# Platform fee percentage (default: 1%)
STRIPE_PLATFORM_FEE_PERCENT=1

# ---- Ollama (AI support triage) ----
# Optional — support tickets will be marked for manual review if not set
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3-coder-next"

# ---- Frontend (public env vars) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
