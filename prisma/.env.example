DATABASE_URL="postgresql://savspot:savspot_dev@localhost:5432/savspot_dev?schema=public"

# DIRECT_URL is used by Prisma Migrate (CLI) and any code path that needs a
# session-mode connection. The Prisma scripts default DIRECT_URL to DATABASE_URL
# when unset, so single-DB local dev works fine without setting this.
# In hosted Supabase: DATABASE_URL = Supavisor pooler (6543), DIRECT_URL = direct (5432).
# DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"
