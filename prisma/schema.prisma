  optimalReminderLeadHours Decimal? @map("optimal_reminder_lead_hours") @db.Decimal(5, 2)
  rebookingIntervalDays    Int?     @map("rebooking_interval_days")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client User   @relation(fields: [clientId], references: [id])

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@map("client_profiles")
}

model GalleryPhoto {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  venueId      String?  @map("venue_id")
  serviceId    String?  @map("service_id")
  category     String?
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  altText      String?  @map("alt_text")
  caption      String?
  isFeatured   Boolean  @default(false) @map("is_featured")
  sortOrder    Int      @default(0) @map("sort_order")
  width        Int?
  height       Int?
  fileSize     Int?     @map("file_size")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venue   Venue?   @relation(fields: [venueId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@map("gallery_photos")
}

model OnboardingTour {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  tourKey        String    @map("tour_key")
  completedAt    DateTime? @map("completed_at")
  dismissedAt    DateTime? @map("dismissed_at")
  stepsCompleted Int       @default(0) @map("steps_completed")
  totalSteps     Int       @default(0) @map("total_steps")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourKey])
  @@map("onboarding_tours")
}

model BookingFlowAnalytics {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  flowId               String   @map("flow_id")
  date                 DateTime @db.Date
  stepMetrics          Json     @map("step_metrics")
  totalSessions        Int      @default(0) @map("total_sessions")
  completedSessions    Int      @default(0) @map("completed_sessions")
  conversionRate       Decimal  @default(0) @map("conversion_rate") @db.Decimal(5, 2)
  totalRevenue         Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  bounceRate           Decimal  @default(0) @map("bounce_rate") @db.Decimal(5, 2)
  avgCompletionTimeSec Int      @default(0) @map("avg_completion_time_sec")
  createdAt            DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingFlow BookingFlow @relation(fields: [flowId], references: [id])

  @@unique([tenantId, flowId, date])
  @@map("booking_flow_analytics")
}

// ---------------------------------------------------------------------------
// 11. Security Domain
// ---------------------------------------------------------------------------

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String?     @map("tenant_id")
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  actorId    String?     @map("actor_id")
  actorType  ActorType   @map("actor_type")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json?
  timestamp  DateTime    @default(now())

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor  User?   @relation(fields: [actorId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([actorId, timestamp])
  @@map("audit_logs")
}

model SecurityBreach {
  id                       String         @id @default(uuid())
  breachType               BreachType     @map("breach_type")
  severity                 BreachSeverity
  status                   BreachStatus
  title                    String
  description              String?
  detectedAt               DateTime       @map("detected_at")
  confirmedAt              DateTime?      @map("confirmed_at")
  containedAt              DateTime?      @map("contained_at")
  resolvedAt               DateTime?      @map("resolved_at")
  gdprNotificationDeadline DateTime?      @map("gdpr_notification_deadline")
  affectedTenantIds        Json?          @map("affected_tenant_ids")
  affectedUserCount        Int?           @map("affected_user_count")
  rootCause                String?        @map("root_cause")
  remediationSteps         String?        @map("remediation_steps")
  assignedTo               String?        @map("assigned_to")
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  // Relations
  assignedToUser      User?                @relation(fields: [assignedTo], references: [id])
  breachNotifications BreachNotification[]
  affectedUsers       AffectedUser[]

  @@index([status])
  @@index([severity])
  @@map("security_breaches")
}

model BreachNotification {
  id            String                          @id @default(uuid())
  breachId      String                          @map("breach_id")
  recipientType BreachNotificationRecipientType @map("recipient_type")
  recipientId   String?                         @map("recipient_id")
  channel       BreachNotificationChannel
  sentAt        DateTime?                       @map("sent_at")
  content       String?
  createdAt     DateTime                        @default(now()) @map("created_at")

  // Relations
  breach SecurityBreach @relation(fields: [breachId], references: [id], onDelete: Cascade)

  @@index([breachId])
  @@map("breach_notifications")
}

model AffectedUser {
  id               String    @id @default(uuid())
  breachId         String    @map("breach_id")
  userId           String    @map("user_id")
  dataTypesExposed Json?     @map("data_types_exposed")
  notifiedAt       DateTime? @map("notified_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  breach SecurityBreach @relation(fields: [breachId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id])

  @@unique([breachId, userId])
  @@map("affected_users")
}

model DataRequest {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  tenantId    String?           @map("tenant_id")
  requestType DataRequestType   @map("request_type")
  status      DataRequestStatus @default(PENDING)
  requestedAt DateTime          @map("requested_at")
  completedAt DateTime?         @map("completed_at")
  deadlineAt  DateTime          @map("deadline_at")
  exportUrl   String?           @map("export_url")
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("data_requests")
}

model ConsentRecord {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  purpose            ConsentPurpose
  consented          Boolean
  consentedAt        DateTime       @map("consented_at")
  withdrawnAt        DateTime?      @map("withdrawn_at")
  ipAddress          String?        @map("ip_address")
  userAgent          String?        @map("user_agent")
  consentTextVersion String?        @map("consent_text_version")
  createdAt          DateTime       @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, purpose])
  @@map("consent_records")
}

// ---------------------------------------------------------------------------
// 12. Reviews
// ---------------------------------------------------------------------------

model Review {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  bookingId   String    @unique @map("booking_id")
  clientId    String    @map("client_id")
  rating      Int
  title       String?
  body        String?
  isPublished Boolean   @default(true) @map("is_published")
  response    String?
  respondedAt DateTime? @map("responded_at")
  respondedBy String?   @map("responded_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking         Booking       @relation(fields: [bookingId], references: [id])
  client          User          @relation("ReviewClient", fields: [clientId], references: [id])
  respondedByUser User?         @relation("ReviewRespondedBy", fields: [respondedBy], references: [id])
  photos          ReviewPhoto[]

  @@index([tenantId])
  @@map("reviews")
}

model ReviewPhoto {
  id           String   @id @default(uuid())
  reviewId     String   @map("review_id")
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_photos")
}

// ---------------------------------------------------------------------------
// API Keys
// ---------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  name       String
  prefix     String
  keyHash    String    @map("key_hash")
  scopes     Json
  rateLimit  Int       @default(60) @map("rate_limit")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")
  allowedIps    String[]  @map("allowed_ips")
  lastRotatedAt DateTime? @map("last_rotated_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  revokedAt     DateTime? @map("revoked_at")

  // Relations
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// Notes (Phase 2)
// ---------------------------------------------------------------------------

model Note {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  authorId   String         @map("author_id")
  entityType NoteEntityType @map("entity_type")
  entityId   String         @map("entity_id")
  body       String
  isPinned   Boolean        @default(false) @map("is_pinned")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
  // Polymorphic: entityId references bookings or users depending on entityType.
  // No FK constraint at database level -- resolved at application layer.

  @@index([tenantId, entityType, entityId])
  @@map("notes")
}

// ---------------------------------------------------------------------------
// Referral Links (Phase 3)
// ---------------------------------------------------------------------------

model ReferralLink {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  code       String
  name              String
  commissionPercent Decimal?  @map("commission_percent") @db.Decimal(5, 2)
  createdBy         String    @map("created_by")
  usageCount Int       @default(0) @map("usage_count")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator  User      @relation(fields: [createdBy], references: [id])
  bookings Booking[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("referral_links")
}

// ---------------------------------------------------------------------------
// 12a. Support Domain
// ---------------------------------------------------------------------------

model SupportTicket {
  id               String            @id @default(uuid())
  tenantId         String?           @map("tenant_id")
  submittedBy      String            @map("submitted_by")
  category         TicketCategory
  severity         TicketSeverity    @default(LOW)
  subject          String
  body             String
  status           TicketStatus      @default(NEW)
  aiDiagnosis      String?           @map("ai_diagnosis")
  aiResponse       String?           @map("ai_response")
  aiResolutionType AIResolutionType? @map("ai_resolution_type")
  resolvedBy       ResolvedBy?       @map("resolved_by")
  resolvedAt       DateTime?         @map("resolved_at")
  developerNotes   String?           @map("developer_notes")
  sourceContext    Json?             @map("source_context")
  userSatisfaction Boolean?          @map("user_satisfaction")
  relatedTicketId  String?           @map("related_ticket_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant?         @relation(fields: [tenantId], references: [id])
  submitter     User            @relation(fields: [submittedBy], references: [id])
  relatedTicket SupportTicket?  @relation("RelatedTickets", fields: [relatedTicketId], references: [id])
  childTickets  SupportTicket[] @relation("RelatedTickets")

  @@index([status, createdAt])
  @@index([submittedBy, category, createdAt])
  @@map("support_tickets")
}

// ---------------------------------------------------------------------------
// 12b. Feedback Domain
// ---------------------------------------------------------------------------

model Feedback {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  submittedBy    String         @map("submitted_by")
  type           FeedbackType
  contextPage    String?        @map("context_page")
  body           String
  screenshotUrl  String?        @map("screenshot_url")
  status         FeedbackStatus @default(NEW)
  developerNotes String?        @map("developer_notes")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submitter User   @relation(fields: [submittedBy], references: [id])

  @@index([tenantId])
  @@map("feedback")
}

// ---------------------------------------------------------------------------
// 13a. Data Import Domain
// ---------------------------------------------------------------------------

model ImportJob {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  sourcePlatform SourcePlatform  @map("source_platform")
  importType     ImportType      @map("import_type")
  status         ImportJobStatus @default(PENDING)
  fileUrl        String?         @map("file_url")
  columnMapping  Json?           @map("column_mapping")
  stats          Json?
  errorLog       Json?           @map("error_log")
  initiatedBy    String?         @map("initiated_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  completedAt    DateTime?       @map("completed_at")

  // Relations
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  initiator User?          @relation(fields: [initiatedBy], references: [id])
  records   ImportRecord[]

  @@index([tenantId])
  @@map("import_jobs")
}

model ImportRecord {
  id           String             @id @default(uuid())
  importJobId  String             @map("import_job_id")
  rowNumber    Int                @map("row_number")
  status       ImportRecordStatus
  targetTable  String             @map("target_table")
  targetId     String?            @map("target_id")
  rawData      Json               @map("raw_data")
  errorMessage String?            @map("error_message")

  // Relations
  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_records")
}

// ---------------------------------------------------------------------------
// Accounting (Phase 3)
// ---------------------------------------------------------------------------

model AccountingConnection {
  id               String                     @id @default(uuid())
  tenantId         String                     @map("tenant_id")
  provider         AccountingProvider
  accessToken      String                     @map("access_token")
  refreshToken     String?                    @map("refresh_token")
  tokenExpiresAt   DateTime?                  @map("token_expires_at")
  companyId        String?                    @map("company_id")
  categoryMappings Json?                      @map("category_mappings")
  lastSyncedAt     DateTime?                  @map("last_synced_at")
  status           AccountingConnectionStatus @default(ACTIVE)
  errorMessage     String?                    @map("error_message")

  // Relations
  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  syncLogs AccountingSyncLog[]

  @@index([tenantId])
  @@map("accounting_connections")
}

// ---------------------------------------------------------------------------
// Browser Push Subscriptions (SRS-4 Section 40a)
// ---------------------------------------------------------------------------

model BrowserPushSubscription {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  endpoint   String
  p256dh     String
  auth       String
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("browser_push_subscriptions")
}

// ---------------------------------------------------------------------------
// Slot Demand Insights (SRS-2 Section 13b — AI Operations)
// ---------------------------------------------------------------------------

model SlotDemandInsight {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  insightType    SlotInsightType @map("insight_type")
  dayOfWeek      Int             @map("day_of_week")
  timeSlot       DateTime        @map("time_slot") @db.Time
  metricValue    Decimal         @map("metric_value") @db.Decimal(5, 4)
  recommendation String
  isDismissed    Boolean         @default(false) @map("is_dismissed")
