// ---------------------------------------------------------------------------
// 3. Platform Tables
// ---------------------------------------------------------------------------

model Tenant {
  id                       String                   @id @default(uuid())
  name                     String
  slug                     String                   @unique
  description              String?
  category                 BusinessCategory
  categoryDescription      String?                  @map("category_description")
  categoryLabel            String?                  @map("category_label")
  logoUrl                  String?                  @map("logo_url")
  coverPhotoUrl            String?                  @map("cover_photo_url")
  brandColor               String?                  @map("brand_color")
  timezone                 String
  currency                 String
  country                  String
  address                  Json?
  contactEmail             String?                  @map("contact_email")
  contactPhone             String?                  @map("contact_phone")
  paymentProvider          PaymentProviderType      @default(STRIPE) @map("payment_provider")
  paymentProviderAccountId String?                  @map("payment_provider_account_id")
  paymentProviderOnboarded Boolean                  @default(false) @map("payment_provider_onboarded")
  subscriptionTier         SubscriptionTier         @default(FREE) @map("subscription_tier")
  subscriptionProviderId   String?                  @map("subscription_provider_id")
  subscriptionStatus       SubscriptionStatus       @default(ACTIVE) @map("subscription_status")
  subscriptionCurrentPeriodEnd DateTime?             @map("subscription_current_period_end")
  subscriptionGracePeriodEnd   DateTime?             @map("subscription_grace_period_end")
  benchmarkOptOut          Boolean                  @default(false) @map("benchmark_opt_out")
  isPublished              Boolean                  @default(false) @map("is_published")
  searchVector             Unsupported("tsvector")? @map("search_vector")
  tosAcceptedAt            DateTime?                @map("tos_accepted_at")
  tosVersion               String?                  @map("tos_version")
  dpaAcceptedAt            DateTime?                @map("dpa_accepted_at")
  dpaVersion               String?                  @map("dpa_version")
  status                   TenantStatus             @default(ACTIVE)
  retentionOverrides       Json?                    @map("retention_overrides")
  isPublic                 Boolean                  @default(false) @map("is_public")
  voicePhoneNumber         String?                  @map("voice_phone_number")
  voiceEnabled             Boolean                  @default(false) @map("voice_enabled")
  voiceConfig              Json?                    @map("voice_config")
  supportedCurrencies      String[]                 @default(["USD"]) @map("supported_currencies")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  // Relations
  memberships              TenantMembership[]
  invitations              TeamInvitation[]
  services                 Service[]
  venues                   Venue[]
  serviceCategories        ServiceCategory[]
  serviceProviders         ServiceProvider[]
  bookingSessions          BookingSession[]
  bookings                 Booking[]
  bookingFlows             BookingFlow[]
  bookingStateHistory      BookingStateHistory[]
  dateReservations         DateReservation[]
  availabilityRules        AvailabilityRule[]
  blockedDates             BlockedDate[]
  payments                 Payment[]
  paymentStateHistory      PaymentStateHistory[]
  paymentDisputes          PaymentDispute[]
  invoices                 Invoice[]
  discounts                Discount[]
  taxRates                 TaxRate[]
  communications           Communication[]
  communicationTemplates   CommunicationTemplate[]
  emailLayouts             EmailLayout[]
  notifications            Notification[]
  calendarConnections      CalendarConnection[]
  calendarEvents           CalendarEvent[]
  contractTemplates        ContractTemplate[]
  contracts                Contract[]
  quotes                   Quote[]
  workflowAutomations      WorkflowAutomation[]
  workflowTemplates        WorkflowTemplate[]
  workflowWebhooks         WorkflowWebhook[]
  bookingReminders         BookingReminder[]
  messageThreads           MessageThread[]
  clientProfiles           ClientProfile[]
  galleryPhotos            GalleryPhoto[]
  reviews                  Review[]
  apiKeys                  ApiKey[]
  notes                    Note[]
  referralLinks            ReferralLink[]
  auditLogs                AuditLog[]
  dataRequests             DataRequest[]
  supportTickets           SupportTicket[]
  feedback                 Feedback[]
  importJobs               ImportJob[]
  accountingConnections    AccountingConnection[]
  bookingFlowAnalytics     BookingFlowAnalytics[]
  serviceAddons            ServiceAddon[]
  browserPushSubscriptions BrowserPushSubscription[]
  slotDemandInsights       SlotDemandInsight[]
  automationExecutions     AutomationExecution[]
  webhookEndpoints         WebhookEndpoint[]
  voiceCallLogs            VoiceCallLog[]
  accountingSyncLogs       AccountingSyncLog[]

  // Phase 4 relations
  directoryListing      DirectoryListing?
  savedBusinesses       SavedBusiness[]
  customDomain          CustomDomain?
  clientRecommendations ClientRecommendation[]
  partnerReferrals      PartnerReferral[]

  @@index([category])
  @@map("tenants")
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String?      @map("password_hash")
  name             String
  phone            String?
  avatarUrl        String?      @map("avatar_url")
  role             PlatformRole @default(USER)
  emailVerified    Boolean      @default(false) @map("email_verified")
  googleId         String?      @unique @map("google_id")
  appleId          String?      @unique @map("apple_id")
  locale           String?
  timezone         String?
  mfaEnabled       Boolean      @default(false) @map("mfa_enabled")
  mfaSecret        String?      @map("mfa_secret")
  mfaRecoveryCodes Json?        @map("mfa_recovery_codes")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  memberships              TenantMembership[]
  invitationsSent          TeamInvitation[]          @relation("InvitedBy")
  bookingSessions          BookingSession[]
  bookingsAsClient         Booking[]                 @relation("BookingClient")
  bookingsCheckedInBy      Booking[]                 @relation("BookingCheckedInBy")
  bookingsCheckedOutBy     Booking[]                 @relation("BookingCheckedOutBy")
  communications           Communication[]
  notifications            Notification[]
  notificationPreference   NotificationPreference?
  notificationDigests      NotificationDigest[]
  devicePushTokens         DevicePushToken[]
  contractSignatures       ContractSignature[]
  contractsVoidedBy        Contract[]                @relation("ContractVoidedBy")
  amendmentsRequestedBy    ContractAmendment[]       @relation("AmendmentRequestedBy")
  amendmentsReviewedBy     ContractAmendment[]       @relation("AmendmentReviewedBy")
  calendarConnections      CalendarConnection[]
  messagesWritten          Message[]
  messageReadStatuses      MessageReadStatus[]
  clientProfiles           ClientProfile[]
  reviewsWritten           Review[]                  @relation("ReviewClient")
  reviewsRespondedTo       Review[]                  @relation("ReviewRespondedBy")
  apiKeysCreated           ApiKey[]
  notesAuthored            Note[]
  referralLinksCreated     ReferralLink[]
  onboardingTours          OnboardingTour[]
  auditLogs                AuditLog[]
  dataRequests             DataRequest[]
  consentRecords           ConsentRecord[]
  affectedUsers            AffectedUser[]
  supportTickets           SupportTicket[]
  feedbackSubmitted        Feedback[]
  importJobsInitiated      ImportJob[]
  serviceProviders         ServiceProvider[]
  blockedDatesCreated      BlockedDate[]
  bookingWorkflowOverrides BookingWorkflowOverride[]
  securityBreachesAssigned SecurityBreach[]
  browserPushSubscriptions BrowserPushSubscription[]
  insightsDismissed        SlotDemandInsight[]       @relation("InsightDismissedBy")
  voiceCallsAsCaller       VoiceCallLog[]            @relation("VoiceCallCaller")

  // Phase 4 relations
  savedBusinesses           SavedBusiness[]
  clientRecommendations     ClientRecommendation[]
  partner                   Partner?
  venueStaffAssignments     VenueStaff[]

  @@map("users")
}

model TenantMembership {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  userId      String     @map("user_id")
  role        TenantRole
  permissions Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

model TeamInvitation {
  id           String           @id @default(uuid())
  tenantId     String           @map("tenant_id")
  invitedBy    String           @map("invited_by")
  inviteeEmail String           @map("invitee_email")
  role         TenantRole
  token        String           @unique
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime         @map("expires_at")
  acceptedAt   DateTime?        @map("accepted_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter User   @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, inviteeEmail, status])
  @@map("team_invitations")
}

// ---------------------------------------------------------------------------
// 4. Booking Domain
// ---------------------------------------------------------------------------

model BookingSession {
  id                   String               @id @default(uuid())
  tenantId             String               @map("tenant_id")
  bookingFlowId        String?              @map("booking_flow_id")
  serviceId            String?              @map("service_id")
  clientId             String?              @map("client_id")
  source               BookingSource        @default(DIRECT)
  currentStep          Int                  @default(0) @map("current_step")
  resolvedSteps        Json                 @map("resolved_steps")
  data                 Json?
  reservationToken     String?              @unique @map("reservation_token")
  reservationExpiresAt DateTime?            @map("reservation_expires_at")
  status               BookingSessionStatus
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingFlow      BookingFlow?      @relation(fields: [bookingFlowId], references: [id])
  service          Service?          @relation(fields: [serviceId], references: [id])
  client           User?             @relation(fields: [clientId], references: [id])
  dateReservations DateReservation[]

  @@index([tenantId])
  @@index([tenantId, status, updatedAt])
  @@map("booking_sessions")
}

model Booking {
  id                     String              @id @default(uuid())
  tenantId               String              @map("tenant_id")
  clientId               String              @map("client_id")
  serviceId              String              @map("service_id")
  venueId                String?             @map("venue_id")
  bookingFlowId          String?             @map("booking_flow_id")
  status                 BookingStatus
  startTime              DateTime            @map("start_time")
  endTime                DateTime            @map("end_time")
  totalAmount            Decimal             @map("total_amount") @db.Decimal(12, 2)
  currency               String
  guestCount             Int?                @map("guest_count")
  guestDetails           Json?               @map("guest_details")
  notes                  String?
  questionnaireResponses Json?               @map("questionnaire_responses")
  source                 BookingSource
  metadata               Json?
  referralLinkId         String?             @map("referral_link_id")
  checkInStatus          CheckInStatus       @default(PENDING) @map("check_in_status")
  checkedInAt            DateTime?           @map("checked_in_at")
  checkedOutAt           DateTime?           @map("checked_out_at")
  checkedInBy            String?             @map("checked_in_by")
  checkedOutBy           String?             @map("checked_out_by")
  originalStartDate      DateTime?           @map("original_start_date") @db.Date
  rescheduleCount        Int                 @default(0) @map("reschedule_count")
  cancellationReason     CancellationReason? @map("cancellation_reason")
  cancelledAt            DateTime?           @map("cancelled_at")
  noShowRiskScore        Decimal?            @map("no_show_risk_score") @db.Decimal(3, 2)
  excessHours            Decimal             @default(0) @map("excess_hours") @db.Decimal(8, 2)
  excessHourFee          Decimal             @default(0) @map("excess_hour_fee") @db.Decimal(8, 2)
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client           User         @relation("BookingClient", fields: [clientId], references: [id])
  service          Service      @relation(fields: [serviceId], references: [id])
  venue            Venue?       @relation(fields: [venueId], references: [id])
  bookingFlow      BookingFlow? @relation(fields: [bookingFlowId], references: [id])
  checkedInByUser  User?        @relation("BookingCheckedInBy", fields: [checkedInBy], references: [id])
  checkedOutByUser User?        @relation("BookingCheckedOutBy", fields: [checkedOutBy], references: [id])

  payments                 Payment[]
  invoices                 Invoice[]
  communications           Communication[]
  bookingStateHistory      BookingStateHistory[]
  contracts                Contract[]
  quotes                   Quote[]
  bookingReminders         BookingReminder[]
  bookingWorkflowOverrides BookingWorkflowOverride[]
  review                   Review?
  calendarEvents           CalendarEvent[]
  messageThreads           MessageThread[]
  referralLink             ReferralLink?             @relation(fields: [referralLinkId], references: [id])
  automationExecutions     AutomationExecution[]
  voiceCallLogs            VoiceCallLog[]

  @@index([tenantId])
  @@index([tenantId, serviceId, status, startTime, endTime])
  @@index([tenantId, clientId])
  @@index([clientId, tenantId, source, status, createdAt])
  @@index([tenantId, startTime])
  @@index([tenantId, status])
  @@index([referralLinkId])
  @@map("bookings")
}

model BookingStateHistory {
  id          String                 @id @default(uuid())
  bookingId   String                 @map("booking_id")
  tenantId    String                 @map("tenant_id")
  fromState   BookingStatus          @map("from_state")
  toState     BookingStatus          @map("to_state")
  reason      String?
  triggeredBy StateTransitionTrigger @map("triggered_by")
  metadata    Json?
  createdAt   DateTime               @default(now()) @map("created_at")

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([tenantId])
  @@map("booking_state_history")
}

model DateReservation {
  id           String                @id @default(uuid())
  tenantId     String                @map("tenant_id")
  sessionId    String                @map("session_id")
  venueId      String?               @map("venue_id")
  serviceId    String                @map("service_id")
  reservedDate DateTime              @map("reserved_date") @db.Date
  startTime    DateTime              @map("start_time")
  endTime      DateTime              @map("end_time")
  token        String                @unique @default(uuid())
  expiresAt    DateTime              @map("expires_at")
  status       DateReservationStatus
  createdAt    DateTime              @default(now()) @map("created_at")

  // Relations
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session BookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  venue   Venue?         @relation(fields: [venueId], references: [id])
  service Service        @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@index([sessionId])
  @@index([serviceId, reservedDate, status])
  @@map("date_reservations")
}

model AvailabilityRule {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  venueId   String?  @map("venue_id")
  serviceId String?  @map("service_id")
  dayOfWeek Int      @map("day_of_week")
  startTime DateTime @map("start_time") @db.Time()
  endTime   DateTime @map("end_time") @db.Time()
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venue   Venue?   @relation(fields: [venueId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@map("availability_rules")
}

model BlockedDate {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  venueId     String?  @map("venue_id")
  serviceId   String?  @map("service_id")
  blockedDate DateTime @map("blocked_date") @db.Date
  reason      String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venue   Venue?   @relation(fields: [venueId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  creator User     @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@map("blocked_dates")
}

model BookingFlow {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  name                  String
  isDefault             Boolean  @default(false) @map("is_default")
  stepOverrides         Json?    @map("step_overrides")
  settings              Json?
  minBookingAdvanceDays Int      @default(1) @map("min_booking_advance_days")
  maxBookingAdvanceDays Int      @default(365) @map("max_booking_advance_days")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingSessions      BookingSession[]
  bookings             Booking[]
  bookingFlowAnalytics BookingFlowAnalytics[]

  @@index([tenantId])
  @@map("booking_flows")
}

// ---------------------------------------------------------------------------
// 5. Payment Domain
// ---------------------------------------------------------------------------

model Payment {
  id                    String        @id @default(uuid())
  tenantId              String        @map("tenant_id")
  bookingId             String        @map("booking_id")
  invoiceId             String?       @map("invoice_id")
  providerTransactionId String?       @map("provider_transaction_id")
  amount                Decimal       @db.Decimal(12, 2)
  platformFee           Decimal?      @map("platform_fee") @db.Decimal(12, 2)
  processingFee         Decimal?      @map("processing_fee") @db.Decimal(12, 2)
  referralCommission    Decimal?      @map("referral_commission") @db.Decimal(12, 2)
  currency              String
  status                PaymentStatus
  type                  PaymentType
  retryCount            Int           @default(0) @map("retry_count")
  nextRetryAt           DateTime?     @map("next_retry_at")
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at")

  // Relations
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking             Booking               @relation(fields: [bookingId], references: [id])
  invoice             Invoice?              @relation(fields: [invoiceId], references: [id])
  paymentStateHistory PaymentStateHistory[]
  paymentDisputes     PaymentDispute[]

  // Note: Payment does not have a direct user FK per SRS-2.
  // The booking.clientId provides the client reference.

  @@index([tenantId])
  @@index([bookingId, status])
  @@index([invoiceId])
  @@index([providerTransactionId])
  @@index([tenantId, createdAt])
  @@map("payments")
}

model PaymentStateHistory {
  id          String                 @id @default(uuid())
  paymentId   String                 @map("payment_id")
  tenantId    String                 @map("tenant_id")
  fromState   PaymentStatus          @map("from_state")
  toState     PaymentStatus          @map("to_state")
  reason      String?
  triggeredBy StateTransitionTrigger @map("triggered_by")
  metadata    Json?
  createdAt   DateTime               @default(now()) @map("created_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([tenantId])
  @@map("payment_state_history")
}

model PaymentDispute {
  id                String        @id @default(uuid())
  paymentId         String        @map("payment_id")
  tenantId          String        @map("tenant_id")
  providerDisputeId String?       @map("provider_dispute_id")
  reason            DisputeReason
  status            DisputeStatus
  amount            Decimal       @db.Decimal(12, 2)
  evidenceDueBy     DateTime?     @map("evidence_due_by")
  resolvedAt        DateTime?     @map("resolved_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paymentId])
  @@map("payment_disputes")
}

model PaymentWebhookLog {
  id              String   @id @default(uuid())
  gateway         String
  eventId         String   @unique @map("event_id")
  eventType       String   @map("event_type")
  rawData         Json     @map("raw_data")
  processed       Boolean  @default(false)
  processingError String?  @map("processing_error")
  retryCount      Int      @default(0) @map("retry_count")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  deadLetters WebhookDeadLetter[]

  @@index([processed, createdAt])
  @@map("payment_webhook_logs")
}

model WebhookDeadLetter {
  id           String    @id @default(uuid())
  webhookLogId String    @map("webhook_log_id")
  finalError   String    @map("final_error")
  retryCount   Int       @default(0) @map("retry_count")
  resolved     Boolean   @default(false)
  resolvedBy   String?   @map("resolved_by")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  webhookLog PaymentWebhookLog @relation(fields: [webhookLogId], references: [id], onDelete: Cascade)

  @@index([webhookLogId])
  @@map("webhook_dead_letters")
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  bookingId      String        @map("booking_id")
  invoiceNumber  String        @map("invoice_number")
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency       String
  status         InvoiceStatus
  dueDate        DateTime?     @map("due_date")
  pdfUrl         String?       @map("pdf_url")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking   Booking           @relation(fields: [bookingId], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([bookingId])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String  @id @default(uuid())
  invoiceId      String  @map("invoice_id")
  description    String
  quantity       Int     @default(1)
  unitPrice      Decimal @map("unit_price") @db.Decimal(12, 2)
  taxRateId      String? @map("tax_rate_id")
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
  sortOrder      Int     @default(0) @map("sort_order")

  // Relations
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxRate TaxRate? @relation(fields: [taxRateId], references: [id])

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ---------------------------------------------------------------------------
// Services, Venues, and Related
// ---------------------------------------------------------------------------

model Service {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  name            String
  description     String?
  durationMinutes Int          @default(60) @map("duration_minutes")
  basePrice       Decimal      @default(0) @map("base_price") @db.Decimal(12, 2)
  currency        String
  pricingModel    PricingModel @default(FIXED) @map("pricing_model")
  isActive        Boolean      @default(true) @map("is_active")
  sortOrder       Int          @default(0) @map("sort_order")

  // Optional complexity fields (null = feature inactive)
  pricingUnit           PricingUnit?             @map("pricing_unit")
  baseHours             Decimal?                 @map("base_hours") @db.Decimal(8, 2)
  excessHourPrice       Decimal?                 @map("excess_hour_price") @db.Decimal(12, 2)
  tierConfig            Json?                    @map("tier_config")
  guestConfig           Json?                    @map("guest_config")
  depositConfig         Json?                    @map("deposit_config")
  intakeFormConfig      Json?                    @map("intake_form_config")
  contractTemplateId    String?                  @map("contract_template_id")
  bufferBeforeMinutes   Int                      @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes    Int                      @default(0) @map("buffer_after_minutes")
  cancellationPolicy    Json?                    @map("cancellation_policy")
  autoCancelOnOverdue   Boolean?                 @map("auto_cancel_on_overdue")
  maxRescheduleCount    Int?                     @map("max_reschedule_count")
  noShowGraceMinutes    Int?                     @map("no_show_grace_minutes")
  confirmationMode      ConfirmationMode         @default(AUTO_CONFIRM) @map("confirmation_mode")
  approvalDeadlineHours Int?                     @map("approval_deadline_hours")
  images                Json?
  preferenceTemplate    Json?                    @map("preference_template")
  venueId               String?                  @map("venue_id")
  categoryId            String?                  @map("category_id")
  searchVector          Unsupported("tsvector")? @map("search_vector")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractTemplate ContractTemplate? @relation(fields: [contractTemplateId], references: [id])
  venue            Venue?            @relation(fields: [venueId], references: [id])
  category         ServiceCategory?  @relation(fields: [categoryId], references: [id])

  bookingSessions   BookingSession[]
  bookings          Booking[]
  dateReservations  DateReservation[]
  availabilityRules AvailabilityRule[]
  blockedDates      BlockedDate[]
  serviceProviders  ServiceProvider[]
  serviceAddons     ServiceAddon[]
  galleryPhotos     GalleryPhoto[]
  quoteLineItems         QuoteLineItem[]
  quoteOptionItems       QuoteOptionItem[]
  clientRecommendations  ClientRecommendation[]

  @@index([tenantId])
  @@map("services")
}

model Venue {
  id           String                   @id @default(uuid())
  tenantId     String                   @map("tenant_id")
  name         String
  description  String?
  address      Json?
  capacity     Int?
  images       Json?
  isActive     Boolean                  @default(true) @map("is_active")
  sortOrder    Int                      @default(0) @map("sort_order")
  searchVector   Unsupported("tsvector")? @map("search_vector")

  // Phase 4 additions
  contactEmail   String?  @map("contact_email")
  contactPhone   String?  @map("contact_phone")
  timezone       String?
  branding       Json?
  bookingSlug    String?  @unique @map("booking_slug")
  operatingHours Json?    @map("operating_hours")

  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  // Relations
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services          Service[]
  bookings          Booking[]
  dateReservations  DateReservation[]
  availabilityRules AvailabilityRule[]
  blockedDates      BlockedDate[]
  galleryPhotos     GalleryPhoto[]
  venueStaff        VenueStaff[]

  @@index([tenantId])
  @@map("venues")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([tenantId])
  @@map("service_categories")
}

model ServiceProvider {
  serviceId String   @map("service_id")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([serviceId, userId])
  @@index([tenantId])
  @@map("service_providers")
}

model ServiceAddon {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  serviceId   String   @map("service_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  isRequired  Boolean  @default(false) @map("is_required")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([serviceId])
  @@map("service_addons")
}

model Discount {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  name           String
  code           String
  type           DiscountType
  value          Decimal             @db.Decimal(12, 2)
  application    DiscountApplication
  validFrom      DateTime?           @map("valid_from")
  validUntil     DateTime?           @map("valid_until")
  usageLimit     Int?                @map("usage_limit")
  usageCount     Int                 @default(0) @map("usage_count")
  minOrderAmount Decimal?            @map("min_order_amount") @db.Decimal(12, 2)
  productScope   Json?               @map("product_scope")
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("discounts")
}

model TaxRate {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String
  rate        Decimal @db.Decimal(7, 5)
  region      String?
  isInclusive Boolean @default(false) @map("is_inclusive")
  isDefault   Boolean @default(false) @map("is_default")
  isActive    Boolean @default(true) @map("is_active")

  // Relations
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@index([tenantId])
  @@map("tax_rates")
}

// ---------------------------------------------------------------------------
// 6. Communication Domain
// ---------------------------------------------------------------------------

model Communication {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  recipientId       String               @map("recipient_id")
  bookingId         String?              @map("booking_id")
  channel           CommunicationChannel
  templateKey       String?              @map("template_key")
  subject           String?
  body              String
  status            CommunicationStatus
  providerMessageId String?              @map("provider_message_id")
  sentAt            DateTime?            @map("sent_at")
  deliveredAt       DateTime?            @map("delivered_at")
  openedAt          DateTime?            @map("opened_at")
  failureReason     String?              @map("failure_reason")
  metadata          Json?
  createdAt         DateTime             @default(now()) @map("created_at")

  // Relations
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient User     @relation(fields: [recipientId], references: [id])
  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@index([tenantId])
  @@index([bookingId])
  @@index([tenantId, recipientId, createdAt])
  @@map("communications")
}

model CommunicationTemplate {
  id               String               @id @default(uuid())
  tenantId         String?              @map("tenant_id")
  key              String
  name             String
  channel          CommunicationChannel
  subjectTemplate  String?              @map("subject_template")
  bodyTemplate     String               @map("body_template")
  layoutId         String?              @map("layout_id")
  isActive         Boolean              @default(true) @map("is_active")
  isSystem         Boolean              @default(false) @map("is_system")
  sandboxValidated Boolean              @default(false) @map("sandbox_validated")
  validationErrors Json?                @map("validation_errors")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  layout          EmailLayout?      @relation(fields: [layoutId], references: [id])
  templateHistory TemplateHistory[]

  @@unique([tenantId, key])
  @@map("communication_templates")
}

model EmailLayout {
  id              String   @id @default(uuid())
  tenantId        String?  @map("tenant_id")
  name            String
  headerTemplate  String?  @map("header_template")
  footerTemplate  String?  @map("footer_template")
  wrapperTemplate String   @map("wrapper_template")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templates CommunicationTemplate[]

  @@index([tenantId])
  @@map("email_layouts")
}

model TemplateHistory {
  id              String   @id @default(uuid())
  templateId      String   @map("template_id")
  version         Int
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String   @map("body_template")
  changedBy       String   @map("changed_by")
  changeReason    String?  @map("change_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  template CommunicationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_history")
}

// ---------------------------------------------------------------------------
// 7. Notification Domain
// ---------------------------------------------------------------------------

model NotificationType {
  id              String               @id @default(uuid())
  key             String               @unique
  name            String
  category        NotificationCategory
  defaultChannels Json                 @map("default_channels")
  priority        NotificationPriority @default(NORMAL)
  autoExpireHours Int?                 @map("auto_expire_hours")
  isSystem        Boolean              @default(false) @map("is_system")
  description     String?

  // Relations
  notifications Notification[]

  @@map("notification_types")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tenantId  String?   @map("tenant_id")
  typeId    String    @map("type_id")
  title     String
  body      String
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notificationType NotificationType @relation(fields: [typeId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([typeId])
  @@map("notifications")
}

model NotificationPreference {
  id                 String          @id @default(uuid())
  userId             String          @unique @map("user_id")
  digestFrequency    DigestFrequency @default(IMMEDIATE) @map("digest_frequency")
  quietHoursStart    DateTime?       @map("quiet_hours_start") @db.Time()
  quietHoursEnd      DateTime?       @map("quiet_hours_end") @db.Time()
  quietHoursTimezone String?         @map("quiet_hours_timezone")
  preferences        Json?
  updatedAt          DateTime        @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationDigest {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  frequency       DigestFrequency
  notificationIds Json            @map("notification_ids")
  status          ReminderStatus
  scheduledFor    DateTime        @map("scheduled_for")
  sentAt          DateTime?       @map("sent_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_digests")
}

model DevicePushToken {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  token        String     @unique
  deviceType   DeviceType @map("device_type")
  deviceName   String?    @map("device_name")
  isActive     Boolean    @default(true) @map("is_active")
  failureCount Int        @default(0) @map("failure_count")
  lastUsedAt   DateTime?  @map("last_used_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_push_tokens")
}

// ---------------------------------------------------------------------------
// 8. Contract & Quote Domain
// ---------------------------------------------------------------------------

model ContractTemplate {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  name                  String
  content               String
  signatureRequirements Json?    @map("signature_requirements")
  category              String?
  isActive              Boolean  @default(true) @map("is_active")
  version               Int      @default(1)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts Contract[]
  services  Service[]

  @@index([tenantId])
  @@map("contract_templates")
}

model Contract {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  bookingId  String         @map("booking_id")
  templateId String         @map("template_id")
  quoteId    String?        @map("quote_id")
  content      String
  documentHash String?        @map("document_hash")
  status       ContractStatus
  expiryDate   DateTime?      @map("expiry_date")
  signedAt   DateTime?      @map("signed_at")
  voidedAt   DateTime?      @map("voided_at")
  voidedBy   String?        @map("voided_by")
  voidReason String?        @map("void_reason")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking      Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  template     ContractTemplate    @relation(fields: [templateId], references: [id])
  quote        Quote?              @relation(fields: [quoteId], references: [id])
  voidedByUser User?               @relation("ContractVoidedBy", fields: [voidedBy], references: [id])
  signatures   ContractSignature[]
  amendments   ContractAmendment[]

  @@index([tenantId])
  @@index([bookingId])
  @@index([templateId])
  @@map("contracts")
}

model ContractSignature {
  id                      String         @id @default(uuid())
  contractId              String         @map("contract_id")
  signerId                String         @map("signer_id")
  role                    SignerRole
  signatureData           String?        @map("signature_data")
  signatureType           SignatureType? @map("signature_type")
  signedAt                DateTime?      @map("signed_at")
  ipAddress               String?        @map("ip_address")
  userAgent               String?        @map("user_agent")
  deviceFingerprint       Json?          @map("device_fingerprint")
  legalDisclosureAccepted Boolean        @default(false) @map("legal_disclosure_accepted")
  electronicConsentAt     DateTime?      @map("electronic_consent_at")
  signatureConfidence     Decimal?       @map("signature_confidence") @db.Decimal(5, 2)
  order                   Int            @default(0)
  createdAt               DateTime       @default(now()) @map("created_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  signer   User     @relation(fields: [signerId], references: [id])

  @@index([contractId])
  @@index([signerId])
  @@map("contract_signatures")
}

model ContractAmendment {
  id              String          @id @default(uuid())
  contractId      String          @map("contract_id")
  requestedBy     String          @map("requested_by")
  status          AmendmentStatus
  sectionsChanged Json?           @map("sections_changed")
  valueChange     Decimal?        @map("value_change") @db.Decimal(12, 2)
  reason          String?
  reviewedBy      String?         @map("reviewed_by")
  reviewedAt      DateTime?       @map("reviewed_at")
  signedAt        DateTime?       @map("signed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requestedByUser User     @relation("AmendmentRequestedBy", fields: [requestedBy], references: [id])
  reviewedByUser  User?    @relation("AmendmentReviewedBy", fields: [reviewedBy], references: [id])

  @@index([contractId])
  @@map("contract_amendments")
}

model Quote {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  bookingId         String      @map("booking_id")
  version           Int         @default(1)
  status            QuoteStatus
  subtotal          Decimal     @db.Decimal(12, 2)
  taxTotal          Decimal     @default(0) @map("tax_total") @db.Decimal(12, 2)
  total             Decimal     @db.Decimal(12, 2)
  currency          String
  validUntil        DateTime?   @map("valid_until")
  notes             String?
  acceptedAt        DateTime?   @map("accepted_at")
  acceptedSignature String?     @map("accepted_signature")
  sentAt            DateTime?   @map("sent_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  lineItems QuoteLineItem[]
  options   QuoteOption[]
  contracts Contract[]

  @@unique([bookingId, version])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quotes")
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  productId   String?  @map("product_id")
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @map("tax_rate") @db.Decimal(7, 5)
  total       Decimal  @db.Decimal(12, 2)
  excessHours Decimal? @map("excess_hours") @db.Decimal(8, 2)
  excessRate  Decimal? @map("excess_rate") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Service? @relation(fields: [productId], references: [id])

  @@index([quoteId])
  @@map("quote_line_items")
}

model QuoteOption {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  name        String
  description String?
  total       Decimal  @db.Decimal(12, 2)
  isSelected  Boolean  @default(false) @map("is_selected")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  quote Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  items QuoteOptionItem[]

  @@index([quoteId])
  @@map("quote_options")
}

model QuoteOptionItem {
  id          String  @id @default(uuid())
  optionId    String  @map("option_id")
  productId   String? @map("product_id")
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(7, 5)
  total       Decimal @db.Decimal(12, 2)

  // Relations
  option  QuoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  product Service?    @relation(fields: [productId], references: [id])

  @@index([optionId])
  @@map("quote_option_items")
}

// ---------------------------------------------------------------------------
// 9. Workflow Domain
// ---------------------------------------------------------------------------

model WorkflowAutomation {
  id           String               @id @default(uuid())
  tenantId     String               @map("tenant_id")
  triggerEvent WorkflowTriggerEvent @map("trigger_event")
  actionType   WorkflowActionType   @map("action_type")
  actionConfig Json                 @map("action_config")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("workflow_automations")
}

model WorkflowTemplate {
  id           String               @id @default(uuid())
  tenantId     String               @map("tenant_id")
  name         String
  description  String?
  triggerEvent WorkflowTriggerEvent @map("trigger_event")
  isDefault    Boolean              @default(false) @map("is_default")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages               WorkflowStage[]
  automationExecutions AutomationExecution[]

  @@index([tenantId])
  @@map("workflow_templates")
}

model WorkflowStage {
  id                   String                             @id @default(uuid())
  templateId           String                             @map("template_id")
  name                 String
  order                Int
  automationType       WorkflowStageAutomationType        @map("automation_type")
  automationConfig     Json                               @map("automation_config")
  triggerTime          WorkflowStageTriggerTime           @map("trigger_time")
  triggerDays          Int?                               @map("trigger_days")
  progressionCondition WorkflowStageProgressionCondition? @map("progression_condition")
  isOptional           Boolean                            @default(false) @map("is_optional")
  createdAt            DateTime                           @default(now()) @map("created_at")

  // Relations
  template                 WorkflowTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  bookingWorkflowOverrides BookingWorkflowOverride[]
  automationExecutions     AutomationExecution[]     @relation("CurrentStage")

  @@unique([templateId, order])
