  computedAt     DateTime        @default(now()) @map("computed_at")

  // Relations
  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dismissedByUser User?  @relation("InsightDismissedBy", fields: [dismissedBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, isDismissed, expiresAt])
  @@map("slot_demand_insights")
}

// ---------------------------------------------------------------------------
// Category Benchmarks (SRS-2 Section 13b — Cross-Tenant Benchmarking)
// ---------------------------------------------------------------------------

model CategoryBenchmark {
  id               String           @id @default(uuid())
  businessCategory BusinessCategory @map("business_category")
  metricKey        String           @map("metric_key")
  p25              Decimal          @db.Decimal(10, 4)
  p50              Decimal          @db.Decimal(10, 4)
  p75              Decimal          @db.Decimal(10, 4)
  sampleSize       Int              @map("sample_size")
  computedAt       DateTime         @default(now()) @map("computed_at")

  @@unique([businessCategory, metricKey])
  @@map("category_benchmarks")
}

// ---------------------------------------------------------------------------
// Phase 3: Automation Executions
// ---------------------------------------------------------------------------

model AutomationExecution {
  id               String                    @id @default(uuid())
  tenantId         String                    @map("tenant_id")
  templateId       String                    @map("template_id")
  bookingId        String?                   @map("booking_id")
  currentStageId   String?                   @map("current_stage_id")
  triggerEvent     WorkflowTriggerEvent      @map("trigger_event")
  triggerEventData Json?                     @map("trigger_event_data")
  status           AutomationExecutionStatus @default(PENDING)
  startedAt        DateTime                  @default(now()) @map("started_at")
  completedAt      DateTime?                 @map("completed_at")
  error            String?
  stageResults     Json?                     @map("stage_results")
  createdAt        DateTime                  @default(now()) @map("created_at")

  // Relations
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template     WorkflowTemplate  @relation(fields: [templateId], references: [id])
  booking      Booking?          @relation(fields: [bookingId], references: [id])
  currentStage WorkflowStage?    @relation("CurrentStage", fields: [currentStageId], references: [id])

  @@index([tenantId])
  @@index([bookingId])
  @@index([status])
  @@map("automation_executions")
}

// ---------------------------------------------------------------------------
// Phase 3: Outgoing Webhooks
// ---------------------------------------------------------------------------

model WebhookEndpoint {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  url             String
  secret          String
  previousSecret  String?   @map("previous_secret")
  secretRotatedAt DateTime? @map("secret_rotated_at")
  events          String[]
  isActive        Boolean   @default(true) @map("is_active")
  maxAttempts     Int       @default(5) @map("max_attempts")
  timeoutSeconds  Int       @default(10) @map("timeout_seconds")
  description     String?
  failureCount    Int       @default(0) @map("failure_count")
  lastFailureAt   DateTime? @map("last_failure_at")
  disabledReason  String?   @map("disabled_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id              String                @id @default(uuid())
  endpointId      String                @map("endpoint_id")
  event           String
  idempotencyKey  String                @unique @map("idempotency_key")
  payload         Json
  requestHeaders  Json?                 @map("request_headers")
  responseStatus  Int?                  @map("response_status")
  responseBody    String?               @map("response_body")
  status          WebhookDeliveryStatus @default(PENDING)
  attemptCount    Int                   @default(0) @map("attempt_count")
  nextRetryAt     DateTime?             @map("next_retry_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  completedAt     DateTime?             @map("completed_at")

  // Relations
  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

// ---------------------------------------------------------------------------
// Phase 3: Voice Call Logs
// ---------------------------------------------------------------------------

model VoiceCallLog {
  id                 String             @id @default(uuid())
  tenantId           String             @map("tenant_id")
  callSid            String             @unique @map("call_sid")
  callerNumber       String             @map("caller_number")
  callerClientId     String?            @map("caller_client_id")
  direction          VoiceCallDirection @default(INBOUND)
  duration           Int?
  status             VoiceCallStatus
  aiHandled          Boolean            @default(false) @map("ai_handled")
  transcript         Json?
  toolCalls          Json?              @map("tool_calls")
  aiConfidenceScores Json?              @map("ai_confidence_scores")
  transferredAt      DateTime?          @map("transferred_at")
  transferredTo      String?            @map("transferred_to")
  recordingUrl       String?            @map("recording_url")
  bookingId          String?            @map("booking_id")
  createdAt          DateTime           @default(now()) @map("created_at")

  // Relations
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking      Booking? @relation(fields: [bookingId], references: [id])
  callerClient User?    @relation("VoiceCallCaller", fields: [callerClientId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
  @@index([callerClientId])
  @@map("voice_call_logs")
}

// ---------------------------------------------------------------------------
// Phase 3: Accounting Sync Logs
// ---------------------------------------------------------------------------

model AccountingSyncLog {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  connectionId    String               @map("connection_id")
  entityType      String               @map("entity_type")
  entityId        String               @map("entity_id")
  direction       String               @default("OUTBOUND")
  status          String               @default("PENDING")
  externalId      String?              @map("external_id")
  idempotencyKey  String               @unique @map("idempotency_key")
  requestPayload  Json?                @map("request_payload")
  responsePayload Json?                @map("response_payload")
  errorMessage    String?              @map("error_message")
  errorCode       String?              @map("error_code")
  retryCount      Int                  @default(0) @map("retry_count")
  syncedAt        DateTime?            @map("synced_at")
  createdAt       DateTime             @default(now()) @map("created_at")

  // Relations
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection AccountingConnection @relation(fields: [connectionId], references: [id])

  @@index([tenantId])
  @@index([connectionId])
  @@index([entityType, entityId])
  @@index([status])
  @@map("accounting_sync_logs")
}

// =============================================================================
// PHASE 4 — PLATFORM METRICS
