model CalendarConnection {
  id                   String                   @id @default(uuid())
  tenantId             String                   @map("tenant_id")
  userId               String                   @map("user_id")
  provider             CalendarProvider
  accessToken          String                   @map("access_token")
  refreshToken         String?                  @map("refresh_token")
  tokenExpiresAt       DateTime?                @map("token_expires_at")
  calendarId           String?                  @map("calendar_id")
  syncDirection        SyncDirection            @default(ONE_WAY) @map("sync_direction")
  syncCalendars        Json?                    @map("sync_calendars")
  syncFrequencyMinutes Int                      @default(15) @map("sync_frequency_minutes")
  lastSyncedAt         DateTime?                @map("last_synced_at")
  status               CalendarConnectionStatus @default(ACTIVE)
  errorMessage         String?                  @map("error_message")
  icalFeedToken        String?                  @unique @map("ical_feed_token")

  // Phase 4 additions
  webhookChannelId String?   @map("webhook_channel_id")
  webhookToken     String?   @map("webhook_token")
  webhookExpiresAt DateTime? @map("webhook_expires_at")
  webhookStatus    String?   @map("webhook_status")
  syncToken        String?   @map("sync_token")
  deltaLink        String?   @map("delta_link")

  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id])
  calendarEvents CalendarEvent[]

  @@index([tenantId])
  @@index([userId])
  @@map("calendar_connections")
}

model CalendarEvent {
  id                   String                 @id @default(uuid())
  tenantId             String                 @map("tenant_id")
  calendarConnectionId String                 @map("calendar_connection_id")
  bookingId            String?                @map("booking_id")
  externalEventId      String?                @map("external_event_id")
  direction            CalendarEventDirection
  startTime            DateTime               @map("start_time")
  endTime              DateTime               @map("end_time")
  title                String?
  syncedAt             DateTime?              @map("synced_at")
  createdAt            DateTime               @default(now()) @map("created_at")

  // Relations
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendarConnection CalendarConnection @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)
  booking            Booking?           @relation(fields: [bookingId], references: [id])

  @@index([tenantId])
  @@index([calendarConnectionId])
  @@index([bookingId])
  @@map("calendar_events")
}

