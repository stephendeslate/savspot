{
  "name": "savspot",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @savspot/prisma generate",
    "db:migrate:dev": "pnpm --filter @savspot/prisma migrate:dev",
    "db:migrate:deploy": "pnpm --filter @savspot/prisma migrate:deploy",
    "db:seed": "pnpm --filter @savspot/prisma seed",
    "db:studio": "pnpm --filter @savspot/prisma studio",
    "start": "./scripts/start.sh",
    "stop": "./scripts/stop.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo run clean && rm -rf node_modules",
    "admin:list-tenants": "tsx scripts/admin/list-tenants.ts",
    "admin:revenue-summary": "tsx scripts/admin/revenue-summary.ts",
    "admin:dead-letter": "tsx scripts/admin/dead-letter.ts",
    "admin:manage-roles": "tsx scripts/admin/manage-roles.ts",
    "admin:suspend-tenant": "tsx scripts/admin/suspend-tenant.ts",
    "admin:platform-config": "tsx scripts/admin/platform-config.ts",
    "admin:import-clients": "tsx scripts/admin/import-clients.ts",
    "admin:import-services": "tsx scripts/admin/import-services.ts",
    "admin:import-appointments": "tsx scripts/admin/import-appointments.ts",
    "admin:feedback": "tsx scripts/admin/feedback.ts",
    "admin:reset-demo": "tsx scripts/admin/reset-demo.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "@sentry/cli", "@swc/core"],
    "overrides": {
      "@types/react": "^19.0.0",
      "tar": ">=7.5.11",
      "multer": ">=2.1.1",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.0",
      "undici": ">=7.24.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
